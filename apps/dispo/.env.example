# Directus
NEXT_PUBLIC_DIRECTUS_URL=https://cms.tc-waiblingen.de
DIRECTUS_TOKEN=

# nuliga-reader
NR_API_URL=https://nr.tc-waiblingen.de
NR_API_TOKEN=
NR_CLUB_ID=20207

# eBuSy court-booking API (https://ebusy.tc-waiblingen.de/api)
EBUSY_API_URL=https://ebusy.tc-waiblingen.de/api
EBUSY_API_USER=
EBUSY_API_PASSWORD=

# Dispo-specific
# 32+ random bytes used to sign the session cookie. Generate with: openssl rand -hex 32
DISPO_SESSION_SECRET=
# Path to the SQLite database file. Use /data/dispo.db in Docker.
DISPO_DB_PATH=./data/dispo.db

# Microsoft Entra (Azure AD) OAuth — leave blank to disable the MS sign-in button.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# App-role value that grants the "admin" role. Anyone signed in via Entra
# without this role becomes an "operator".
ENTRA_ADMIN_ROLE=Dispo.Admin
