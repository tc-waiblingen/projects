{
  "name": "@tcw/website",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "pagefind --site .next/standalone/.next/server/app --output-path public/_pagefind --force-language de",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf .next/cache",
    "generate:types": "tsx ./src/lib/directus/generateDirectusTypes.ts",
    "generate:secret": "node scripts/generate-signing-secret.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ],
    "tailwindStylesheet": "./src/app/globals.css",
    "tailwindFunctions": [
      "clsx"
    ]
  },
  "dependencies": {
    "@directus/sdk": "^21.0.0",
    "@directus/visual-editing": "^1.1.0",
    "@headlessui/react": "^2.2.9",
    "@tailwindplus/elements": "^1.0.21",
    "@tcw/calendar": "workspace:*",
    "clsx": "^2.1.1",
    "ical-generator": "^10.0.0",
    "isomorphic-dompurify": "^2.35.0",
    "libphonenumber-js": "^1.12.34",
    "next": "^16",
    "p-queue": "^9.1.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "directus-sdk-typegen": "^0.2.1",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "jsdom": "^27.4.0",
    "next-devtools-mcp": "^0.3.10",
    "pagefind": "^1.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
