{
  "name": "@tcw/website",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "pagefind --site .next/standalone/apps/website/.next/server/app --output-path public/_pagefind --force-language de",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf .next/cache",
    "generate:types": "tsx ./src/lib/directus/generateDirectusTypes.ts",
    "generate:secret": "node scripts/generate-signing-secret.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ],
    "tailwindStylesheet": "./src/app/globals.css",
    "tailwindFunctions": [
      "clsx"
    ]
  },
  "dependencies": {
    "@directus/sdk": "^21.2.0",
    "@directus/visual-editing": "^2.0.0",
    "@headlessui/react": "^2.2.9",
    "@tailwindplus/elements": "^1.0.22",
    "@tcw/calendar": "workspace:*",
    "@tcw/email": "workspace:*",
    "clsx": "^2.1.1",
    "ical-generator": "^10.1.0",
    "isomorphic-dompurify": "^3.7.1",
    "libphonenumber-js": "^1.12.40",
    "marked": "^17.0.5",
    "next": "^16.2.1",
    "node-html-parser": "^7.1.0",
    "p-queue": "^9.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "directus-sdk-typegen": "^0.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "next-devtools-mcp": "^0.3.10",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}