# URL of your Directus instance (no slash at the end).
NEXT_PUBLIC_DIRECTUS_URL=https://cms.tc-waiblingen.de

# Private token for accessing private resources in Directus. Use the token from the "Private Bot" account.
DIRECTUS_TOKEN=

# Public token for accessing public resources in Directus. Use the token from the "Public Bot" account.
DIRECTUS_PUBLIC_TOKEN=

# Token from the **Frontend Bot User** account in Directus for handling form submissions.
DIRECTUS_FORM_TOKEN=

# The public URL of your site. This is used for SEO metadata and blog post routing.
NEXT_PUBLIC_SITE_URL=https://tc-waiblingen.de/

# The secret you generate for live preview. This is used to view draft posts in directus and live edits.
DRAFT_MODE_SECRET=

# Enable or disable visual editing in Directus
NEXT_PUBLIC_ENABLE_VISUAL_EDITING=true

# Instagram API credentials
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# URL signing secret for generating signed URLs for protected resources
URL_SIGNING_SECRET=

# Secret for Directus webhook to trigger on-demand cache revalidation
REVALIDATION_SECRET=

# nuliga-reader service (https://nr.tc-waiblingen.de)
NR_API_URL=https://nr.tc-waiblingen.de
NR_API_TOKEN=
NR_CLUB_ID=20207

# eBuSy court-booking API (https://ebusy.tc-waiblingen.de/api)
EBUSY_API_URL=https://ebusy.tc-waiblingen.de/api
EBUSY_API_USER=
EBUSY_API_PASSWORD=

# dispo court-assignment app (https://dispo.tc-waiblingen.de)
DISPO_API_URL=https://dispo.tc-waiblingen.de
